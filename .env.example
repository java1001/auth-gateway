APP_PORT=8080

# Secrets (generate each with: openssl rand -hex 32)
JWT_SECRET=secret-for-user-session-tokens-change-me
OAUTH_STATE_SECRET=different-secret-for-oauth-state-jwt-change-me
OAUTH_TOKEN_ENCRYPTION_KEY=yet-another-secret-for-aes-gcm-token-storage

# Resend transactional email settings.
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=no-reply@yourdomain.com

# Gateway public base URL used for OAuth callbacks.
GATEWAY_BASE_URL=https://auth.yourdomain.com

# Domain whitelist for site origins that may call the gateway.
ALLOW_SITES=site1.com,site2.com

# Google OAuth 2.0 web application credentials.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twitter/X OAuth 2.0 web application credentials.
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# One database per site. Every SITE_*_HOST must also appear in ALLOW_SITES.
SITE_SITE1_HOST=site1.com
SITE_SITE1_DSN=postgres://user:pass@localhost:5432/site1_auth?sslmode=disable

SITE_SITE2_HOST=site2.com
SITE_SITE2_DSN=postgres://user:pass@localhost:5432/site2_auth?sslmode=disable
